{
  "entities": {
    "Item": {
      "title": "Inventory Item",
      "description": "Represents an IT asset or supply in the hospital inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The SKU or item code, e.g., IT-NET-001" },
        "name": { "type": "string", "description": "Name of the item" },
        "category": { "type": "string", "description": "Category of the item (e.g., Networking, End-user Devices, Peripherals, Others)" },
        "quantity": { "type": "number", "description": "Current quantity in stock" },
        "withdrawCount": { "type": "number", "description": "Total quantity withdrawn" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., rolls, pieces, units)" },
        "price": { "type": "number", "description": "Unit price in Thai Baht" },
        "minThreshold": { "type": "number", "description": "Minimum threshold before triggering low stock warning" },
        "status": { "type": "string", "description": "Status: IN STOCK, LOW STOCK, OUT OF STOCK" },
        "image": { "type": "string", "description": "URL of the item image" },
        "updatedAt": { "type": "string", "description": "ISO-8601 timestamp of last update" }
      },
      "required": ["id", "name", "category", "quantity", "unit", "price", "status"]
    },
    "Transaction": {
      "title": "Inventory Transaction",
      "description": "Represents a log of item withdraw or restock action.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID" },
        "itemId": { "type": "string", "description": "Associated Item ID" },
        "itemName": { "type": "string", "description": "Associated Item Name" },
        "type": { "type": "string", "enum": ["WITHDRAW", "RESTOCK"], "description": "Action type" },
        "quantity": { "type": "number", "description": "Quantity transacted" },
        "memberName": { "type": "string", "description": "Hospital staff name involved" },
        "date": { "type": "string", "description": "ISO-8601 timestamp" },
        "notes": { "type": "string", "description": "Optional notes" }
      },
      "required": ["id", "itemId", "itemName", "type", "quantity", "memberName", "date"]
    },
    "Member": {
      "title": "Hospital Member",
      "description": "Represents a staff member authorized to withdraw assets.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Member ID" },
        "name": { "type": "string", "description": "Full name of staff" },
        "department": { "type": "string", "description": "Hospital department" },
        "email": { "type": "string", "description": "Contact email" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "withdrawCount": { "type": "number", "description": "Count of withdraw operations" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"], "description": "Membership status" }
      },
      "required": ["id", "name", "department", "email", "status"]
    }
  },
  "firestore": {
    "items/{itemId}": {
      "schema": "Item",
      "description": "Primary hospital IT supplies inventory."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Logs of item withdrawals and stock refills."
    },
    "members/{memberId}": {
      "schema": "Member",
      "description": "Hospital members permitted to request IT stock items."
    }
  }
}
